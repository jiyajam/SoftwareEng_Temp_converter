pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'Java21'
    }

    environment {
        DOCKERHUB_CREDENTIALS_ID = 'Docker_Hub'
        DOCKERHUB_REPO = 'jiyak/softwareeng_temp_converter'
        DOCKER_IMAGE_TAG = 'latest'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/jiyajam/SoftwareEng_Temp_converter.git'
            }
        }

        stage('Run Tests') {
            steps {
                // Prepend /usr/local/bin to PATH only for this stage
                withEnv(["PATH=/usr/local/bin:${env.PATH}"]) {
                    sh 'mvn clean verify'
                }
            }
        }

        stage('Code Coverage') {
            steps {
                withEnv(["PATH=/usr/local/bin:${env.PATH}"]) {
                    sh 'mvn jacoco:report'
                }
            }
        }

        stage('Publish Test Results') {
            steps {
                junit '**/target/surefire-reports/*.xml'
            }
        }

        stage('Publish Coverage Report') {
            steps {
                jacoco()
            }
        }

        stage('Build Docker Image') {
            steps {
                withEnv(["PATH=/usr/local/bin:${env.PATH}"]) {
                    script {
                        docker.build("${env.DOCKERHUB_REPO}:${env.DOCKER_IMAGE_TAG}")
                    }
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                withEnv(["PATH=/usr/local/bin:${env.PATH}"]) {
                    script {
                        docker.withRegistry('https://index.docker.io/v1/', "${env.DOCKERHUB_CREDENTIALS_ID}") {
                            docker.image("${env.DOCKERHUB_REPO}:${env.DOCKER_IMAGE_TAG}").push()
                        }
                    }
                }
            }
        }

    }

    post {
        always {
            cleanWs()
        }
        success {
            echo 'Pipeline succeeded!'
        }
        failure {
            echo 'Pipeline failed.'
        }
    }
}