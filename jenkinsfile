pipeline {
    agent any

    tools {
        maven 'Maven3'    // name of Maven installation in Jenkins
        jdk 'Java21'      // name of Java installation in Jenkins
    }

    environment {
        DOCKERHUB_CREDENTIALS_ID = 'Docker_Hub'      // Jenkins credential ID for Docker Hub
        DOCKERHUB_REPO = 'jiyak/softwareeng_temp_converter'
        DOCKER_IMAGE_TAG = 'latest'
    }

    stages {

        stage('Checkout') {
            steps {
                // Explicitly checkout the main branch
                git branch: 'main', url: 'https://github.com/jiyajam/SoftwareEng_Temp_converter.git'
            }
        }

        stage('Run Tests') {
            steps {
                // Run tests and verify build
                sh 'mvn clean verify'
            }
        }

        stage('Code Coverage') {
            steps {
                sh 'mvn jacoco:report'
            }
        }

        stage('Publish Test Results') {
            steps {
                junit '**/target/surefire-reports/*.xml'
            }
        }

        stage('Publish Coverage Report') {
            steps {
                jacoco()
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    docker.build("${env.DOCKERHUB_REPO}:${env.DOCKER_IMAGE_TAG}")
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    docker.withRegistry('https://index.docker.io/v1/', "${env.DOCKERHUB_CREDENTIALS_ID}") {
                        docker.image("${env.DOCKERHUB_REPO}:${env.DOCKER_IMAGE_TAG}").push()
                    }
                }
            }
        }

    }

    post {
        always {
            cleanWs()  // Clean workspace after build
        }
        success {
            echo 'Pipeline succeeded!'
        }
        failure {
            echo 'Pipeline failed.'
        }
    }
}